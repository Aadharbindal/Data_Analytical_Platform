# LiteLLM Provider Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
LLM_MODEL=groq/llama-3.1-8b-instant
# Data Infrastructure Configuration
DATA_DIR=data
SQLITE_PATH=data/datamind.db
MAX_UPLOAD_MB=50
PORT=8000
# Auth
# Required in production - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, a random key is generated on every restart, which invalidates all sessions.
SECRET_KEY=
# CORS - set to your deployed frontend URL(s)
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=
# Comma-separated list of extra allowed origins (e.g. Vercel preview URLs)
ALLOWED_ORIGINS=
# PostgreSQL Database URL (e.g. postgresql://user:password@localhost:5432/dbname)
DATABASE_URL=
# Email verification (Resend: https://resend.com — free tier available)
# If unset, signup/login still work but no verification email is sent.
RESEND_API_KEY=
EMAIL_FROM=DataMind <onboarding@resend.dev>

